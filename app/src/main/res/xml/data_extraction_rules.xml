<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules xmlns:tools="http://schemas.android.com/tools">
    <cloud-backup>
        <exclude
            domain="sharedpref"
            path="crash.xml" />
        <exclude
            domain="file"
            path="error"
            tools:ignore="FullBackupContent" />
    </cloud-backup>
    <device-transfer>
        <exclude
            domain="sharedpref"
            path="crash.xml" />
        <exclude
            domain="file"
            path="error"
            tools:ignore="FullBackupContent" />
    </device-transfer>
</data-extraction-rules>